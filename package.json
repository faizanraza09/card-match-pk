{
  "name": "konsacard",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the KonsaCard web + mobile apps",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm start --workspace=apps/mobile",
    "test:web": "npm test --workspace=apps/web",
    "test:mobile": "npx --workspace=apps/mobile jest",
    "build:web": "npm run build --workspace=apps/web",
    "refresh:offers": "npm run refresh:offers --workspace=apps/web",
    "refresh:requirements": "npm run refresh:requirements --workspace=apps/web"
  }
}
